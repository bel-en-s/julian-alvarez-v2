{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/genesis/layout,_N_T_/genesis/page,_N_T_/genesis"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/genesis/__PAGE__",
    "/genesis",
    "/_index",
    "/_head"
  ]
}