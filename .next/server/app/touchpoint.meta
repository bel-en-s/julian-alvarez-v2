{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/touchpoint/layout,_N_T_/touchpoint/page,_N_T_/touchpoint"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/touchpoint/__PAGE__",
    "/touchpoint",
    "/_index",
    "/_head"
  ]
}